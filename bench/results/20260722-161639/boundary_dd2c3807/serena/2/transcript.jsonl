)\n\n\tkeyId1 := dkvs[0].GetPrivateId()\n\tkeyId2 := dkvs[1].GetPrivateId()\n\n\t// First test: just getting the key should return the latest\n\twrapper, err := kmsCache.GetWrapper(ctx, scope.Global.String(), KeyPurposeDatabase)\n\trequire.NoError(err)","metadata":{"truncated":false},"title":"","time":{"start":1784788089986,"end":1784788090078},"attachments":[]},"id":"prt_f8da8fbb7001Q8kaiI52brf2v7","sessionID":"ses_07258372efferEjBD8N053CL63","messageID":"msg_f8da8f910001LTiNbAoO1B0IZ6"}}
