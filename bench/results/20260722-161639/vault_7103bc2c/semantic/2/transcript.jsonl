t\\treturn be.Reload(ctx)\\n\\t\\t})\\n\\nn21: \\t\\tc.reloadFuncsLock.Unlock()\\nn22: \\tcase \\\"socket\\\":\\nn23: \\t\\tif auditLogger.IsDebug() {\\nn24: \\t\\t\\tif entry.Options != nil {\\nn25: \\t\\t\\t\\tauditLogger.Debug(\\\"socket backend options\\\", \\\"path\\\", entry.Path, \\\"address\\\", entry.Options[\\\"address\\\"], \\\"socket type\\\", entry.Options[\\\"socket_type\\\"])\\n\\t\\t\\t}\\n\\t\\t}\\nn26: \\tcase \\\"syslog\\\":\\nn27: \\t\\tif auditLogger.IsDebug() {\\nn28: \\t\\t\\tif entry.Options != nil {\\nn29: \\t\\t\\t\\tauditLogger.Debug(\\\"syslog backend options\\\", \\\"path\\\", entry.Path, \\\"facility\\\", entry.Options[\\\"facility\\\"], \\\"tag\\\", entry.Options[\\\"tag\\\"])\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\nn30: \\treturn be, err\\n}\\n\"\n}\n","metadata":{"truncated":false},"title":"","time":{"start":1784783612827,"end":1784783612840},"attachments":[]},"id":"prt_f8d64ab0f001QmOxQB3OJUq4Fg","sessionID":"ses_0729bbff0ffeCFghNGA2j8YtKV","messageID":"msg_f8d64a210001iF6hK1tMaJ5qFU"}}
